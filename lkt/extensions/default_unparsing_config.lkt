class GrammarRuleDecl {
    val node =
        [
            recurse(f_syn_name),
            whitespace,
            "<-",
            match f_expr {
                case TokenLit | TokenPatternLit =>
                    indent(group(line, recurse(f_expr)))
                case _ => [whitespace, recurse(f_expr)]
            }
        ]
}

