class LambdaExpr {
    val node =
        [
            "(",
            recurse(f_params),
            ")",
            recurse(f_return_type),
            whitespace,
            group(
                "=>",
                flushLineBreaks,
                id="comments",
                bubbleUpTrailingTrivias=false
            ),
            match f_body {
                case BlockExpr =>
                    [
                        ifBreak([], whitespace, groupId="comments"),
                        recurse(f_body)
                    ]
                case _ =>
                    group(
                        ifBreak([], line, groupId="comments"),
                        recurse(f_body)
                    )
            }
        ]
    val f_params = group(indent(softline, recurse), softline)
    val f_return_type = [":", whitespace, recurse]
}

class LangkitRoot {
    val f_imports = [recurse, ifEmpty([], hardline)]
}

class LexerCaseRule {
    val node =
