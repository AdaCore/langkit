class FunParamDecl {
    val node =
        [
            recurse(f_decl_annotations),
            recurse(f_syn_name),
            ":",
            whitespace,
            recurse(f_decl_type),
            recurse(f_default_val)
        ]
    val f_default_val = [whitespace, "=", group(indent(line, recurse))]
}

class FunParamDeclList {
    val sep = [recurse, line]
