        [
            "class",
            recurse(f_syn_name),
            recurse(f_syn_base_type),
            recurse(f_traits),
            whitespace,
            "{",
            recurse(f_decls),
            "}"
        ]
    val f_syn_base_type = [":", whitespace, recurse]
    val f_traits = [whitespace, "implements", recurse]
    val f_decls =
        [ifEmpty([hardline, recurse], [indent(hardline, recurse), hardline])]
}

