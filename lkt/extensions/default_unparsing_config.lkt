class EnumClassDecl {
    val node =
        [
            "enum",
            "class",
            recurse(f_syn_name),
            recurse(f_syn_base_type),
            recurse(f_traits),
            whitespace,
            "{",
            indent(recurse(f_branches), recurse(f_decls)),
            hardline,
            "}"
        ]
    val f_syn_base_type = [":", whitespace, recurse]
    val f_branches = ifEmpty([recurse], [hardline, recurse])
    val f_decls = ifEmpty([recurse], [hardline, recurse])
}

