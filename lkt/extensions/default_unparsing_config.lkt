class FieldDecl {
    val node =
        [
            recurse(f_syn_name),
            ":",
            whitespace,
            recurse(f_decl_type),
            recurse(f_trait_ref),
            recurse(f_default_val)
        ]
    val f_trait_ref = [whitespace, recurse]
    val f_default_val =
        [
            whitespace,
            "=",
            match node {
                case BlockExpr => [whitespace, recurse]
                case ParenExpr => [whitespace, recurse]
                case _ => group(indent(line, recurse))
            }
        ]
}

