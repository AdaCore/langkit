{
  "node_configs": {
    "VarDecl": {
      "fields": {
        "f_is_null": {
          "kind": "match",
          "node": "this_field",
          "matchers": [
            {
              "pattern": {"kind": "node", "type": "NullQualPresent"},
              "document": ["recurse", "hardline"]
            },
            {
              "pattern": "*",
              "document": ["whitespace", "recurse"]
            }
          ]
        }
      }
    }
  }
}
