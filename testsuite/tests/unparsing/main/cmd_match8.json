{
  "node_configs": {
    "MinusExpr": {
      "node": [
        {
          "kind": "text",
          "text": "-"
        },
        {
          "kind": "match",
          "node": {
            "kind": "eval_member",
            "prefix": "this_node",
            "member": "f_args"
          },
          "matchers": [
            {
              "pattern": {
                "kind": "node",
                "type": "NameList",
                "members": [
                  {
                    "member": "is_empty_list",
                    "pattern": true
                  }
                ]
              },
              "document": [
                "hardline",
                {
                  "kind": "recurse_field",
                  "field": "f_prefix"
                }
              ]
            },
            {
              "pattern": "*",
              "document": {
                "kind": "recurse_field",
                "field": "f_prefix"
              }
            }
          ]
        },
        {
          "kind": "recurse_field",
          "field": "f_args"
        }
      ]
    }
  }
}
