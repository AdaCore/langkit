## vim: filetype=makopython

<%
    language_mode_type = pyapi.type_public_name(T.LanguageMode)
%>

    @classmethod
    def create_default(cls, mode: ${language_mode_type}) -> UnitProvider:
        ${py_doc("liblktlang.create_default_provider", 8)}
        c_value = _create_default_provider(
            ${pyapi.unwrap_value("mode", T.LanguageMode, "")},
        )
        return _CUnitProvider(c_value)

    @classmethod
    def from_directories(
        cls,
        mode: ${language_mode_type},
        directories: list[str],
    ) -> UnitProvider:
        ${py_doc("liblktlang.create_default_provider_from_directories", 8)}
        # Create a NULL-terminated array of strings
        c_strings = [
            ctypes.c_char_p(
                _coerce_bytes("directories", d, "a list of bytes strings")
            )
            for d in directories
        ]
        c_array_type = ctypes.c_char_p * (len(directories) + 1)
        c_array = c_array_type()
        for i, c_str in enumerate(c_strings):
            c_array[i] = c_str
        c_array[-1] = None

        c_array_ptr = ctypes.pointer(c_array)
        directories_arg = ctypes.cast(
            c_array_ptr, ctypes.POINTER(ctypes.c_char_p)
        )

        c_value = _create_default_provider_from_directories(
            ${pyapi.unwrap_value("mode", T.LanguageMode, "")},
            directories_arg,
            len(directories),
        )
        return _CUnitProvider(c_value)
