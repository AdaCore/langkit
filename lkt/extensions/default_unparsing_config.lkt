class ElsifBranch {
    val node =
        [
            hardline,
            "elif",
            whitespace,
            recurse(f_cond_expr),
            group(line, "then", whitespace, recurse(f_then_expr))
        ]
    val f_cond_expr = match node {
        case BlockExpr | ParenExpr => recurse
        case _ => group(indent(softline, recurse))
    }
    val f_then_expr = match node {
        case BlockExpr | ParenExpr => recurse
        case _ => group(indent(softline, recurse))
    }
}

class ElsifBranchList {
    val flush_before_children = false
}

