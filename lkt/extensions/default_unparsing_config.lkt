class FunDecl {
    val node =
        [
            "fun",
            recurse(f_syn_name),
            "(",
            group(indent(softline, recurse(f_params)), softline),
            ")",
            ":",
            whitespace,
            recurse(f_return_type),
            recurse(f_trait_ref),
            recurse(f_body)
        ]
    val f_trait_ref = [whitespace, "implements", recurse]
    val f_body =
        [
            whitespace,
            match node {
                case BlockExpr | MatchExpr => ["=", whitespace, recurse]
                case _ => group(indent("=", line, recurse))
            }
        ]
}

