class IfExpr {
    val node =
        group(
            group(
                "if",
                whitespace,
                recurse(f_cond_expr),
                line,
                "then",
                whitespace,
                recurse(f_then_expr)
            ),
            group(recurse(f_alternatives)),
            line,
            group("else", whitespace, recurse(f_else_expr))
        )
    val f_cond_expr = match node {
        case BlockExpr | ParenExpr => recurse
        case _ => group(indent(softline, recurse))
    }
    val f_else_expr = match node {
        case BlockExpr | ParenExpr => recurse
        case _ => group(indent(softline, recurse))
    }
    val f_then_expr = match node {
        case BlockExpr | ParenExpr => recurse
        case _ => group(indent(softline, recurse))
    }
}

