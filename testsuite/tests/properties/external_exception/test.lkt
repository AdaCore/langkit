# Check that external exceptions allowed to be raised in properties:
#
# * can be raised directly from Lkt code;
# * yield valid generated code.

from lexer_example import foo_lexer

@with_lexer(foo_lexer)
grammar foo_grammar {
    @main_rule main_rule <- list*(Example("example"))
}

@abstract
class FooNode implements Node[FooNode] {
    @exported
    fun do_raise(): Bool = raise[Bool] MyException("raised from Lkt")
}

class Example: FooNode implements TokenNode {
}
